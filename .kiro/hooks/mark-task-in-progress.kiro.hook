{
  "enabled": true,
  "name": "Mark Task In Progress",
  "description": "Automatically marks task as in_progress when starting task execution",
  "version": "1",
  "when": {
    "type": "preTaskExecution"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Before starting this task, mark it as in_progress using the taskStatus tool."
  }
}
