{
  "name": "amigo-infrastructure",
  "version": "1.0.0",
  "description": "AWS CDK infrastructure for Amigo health app",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "deploy": "cdk deploy --all",
    "deploy:dev": "cdk deploy --all --context environment=dev",
    "deploy:staging": "cdk deploy --all --context environment=staging",
    "deploy:prod": "cdk deploy --all --context environment=prod",
    "synth": "cdk synth",
    "diff": "cdk diff"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "aws-cdk": "^2.140.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.140.0",
    "constructs": "^10.0.0",
    "dotenv": "^17.3.1",
    "source-map-support": "^0.5.21"
  }
}
