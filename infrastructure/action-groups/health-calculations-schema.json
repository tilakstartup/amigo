{
  "openapi": "3.0.0",
  "info": {
    "title": "Amigo Health Calculations API",
    "version": "1.0.0",
    "description": "Health calculation tools for BMR, TDEE, goal validation, and macro calculations"
  },
  "paths": {
    "/calculate-bmr": {
      "post": {
        "summary": "Calculate Basal Metabolic Rate using Mifflin-St Jeor equation",
        "description": "Calculates the user's BMR based on weight, height, age, and gender",
        "operationId": "calculateBMR",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "weight_kg": {
                    "type": "number",
                    "description": "Weight in kilograms"
                  },
                  "height_cm": {
                    "type": "number",
                    "description": "Height in centimeters"
                  },
                  "age": {
                    "type": "integer",
                    "description": "Age in years"
                  },
                  "gender": {
                    "type": "string",
                    "enum": ["male", "female"],
                    "description": "User's gender"
                  }
                },
                "required": ["weight_kg", "height_cm", "age", "gender"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "BMR calculated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "bmr": {
                      "type": "number",
                      "description": "Basal Metabolic Rate in kcal/day"
                    },
                    "unit": {
                      "type": "string",
                      "description": "Unit of measurement"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/calculate-tdee": {
      "post": {
        "summary": "Calculate Total Daily Energy Expenditure",
        "description": "Calculates TDEE by multiplying BMR with activity level multiplier",
        "operationId": "calculateTDEE",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "bmr": {
                    "type": "number",
                    "description": "Basal Metabolic Rate in kcal/day"
                  },
                  "activity_level": {
                    "type": "string",
                    "enum": [
                      "sedentary",
                      "lightly active",
                      "moderately active",
                      "very active",
                      "extra active"
                    ],
                    "description": "Activity level"
                  }
                },
                "required": ["bmr", "activity_level"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "TDEE calculated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tdee": {
                      "type": "number",
                      "description": "Total Daily Energy Expenditure in kcal/day"
                    },
                    "activity_multiplier": {
                      "type": "number",
                      "description": "Multiplier used for activity level"
                    },
                    "unit": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/validate-goal": {
      "post": {
        "summary": "Validate if a health goal is realistic",
        "description": "Checks if target weight and timeline are achievable and healthy",
        "operationId": "validateGoal",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "current_weight_kg": {
                    "type": "number",
                    "description": "Current weight in kilograms"
                  },
                  "target_weight_kg": {
                    "type": "number",
                    "description": "Target weight in kilograms"
                  },
                  "target_date": {
                    "type": "string",
                    "format": "date",
                    "description": "Target date to achieve goal"
                  },
                  "tdee": {
                    "type": "number",
                    "description": "Total Daily Energy Expenditure"
                  }
                },
                "required": ["current_weight_kg", "target_weight_kg", "target_date", "tdee"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Goal validation complete",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "is_realistic": {
                      "type": "boolean",
                      "description": "Whether the goal is realistic and healthy"
                    },
                    "daily_calories": {
                      "type": "number",
                      "description": "Recommended daily calorie target"
                    },
                    "weekly_rate_kg": {
                      "type": "number",
                      "description": "Expected weight change per week"
                    },
                    "reasoning": {
                      "type": "string",
                      "description": "Explanation of validation result"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/calculate-macros": {
      "post": {
        "summary": "Calculate recommended macronutrient breakdown",
        "description": "Calculates protein, carbs, and fat targets based on daily calories and goal type",
        "operationId": "calculateMacros",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "daily_calories": {
                    "type": "number",
                    "description": "Daily calorie target"
                  },
                  "goal_type": {
                    "type": "string",
                    "enum": ["weight_loss", "muscle_gain", "maintenance"],
                    "description": "Type of health goal"
                  }
                },
                "required": ["daily_calories", "goal_type"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Macros calculated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "protein_g": {
                      "type": "number",
                      "description": "Daily protein target in grams"
                    },
                    "carbs_g": {
                      "type": "number",
                      "description": "Daily carbohydrate target in grams"
                    },
                    "fat_g": {
                      "type": "number",
                      "description": "Daily fat target in grams"
                    },
                    "protein_kcal": {
                      "type": "number",
                      "description": "Calories from protein"
                    },
                    "carbs_kcal": {
                      "type": "number",
                      "description": "Calories from carbohydrates"
                    },
                    "fat_kcal": {
                      "type": "number",
                      "description": "Calories from fat"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
