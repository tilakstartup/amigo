{
  "openapi": "3.0.0",
  "info": {
    "title": "Amigo Pattern Analysis API",
    "version": "1.0.0",
    "description": "Analyze user behavior patterns and generate personalized insights"
  },
  "paths": {
    "/analyze-eating-patterns": {
      "post": {
        "summary": "Analyze eating patterns",
        "description": "Identify patterns in meal timing, frequencies, and food choices",
        "operationId": "analyzeEatingPatterns",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "user_id": {
                    "type": "string",
                    "description": "User ID (UUID)"
                  },
                  "lookback_days": {
                    "type": "integer",
                    "description": "Number of days to analyze",
                    "minimum": 7,
                    "maximum": 90,
                    "default": 30
                  },
                  "include_recommendations": {
                    "type": "boolean",
                    "description": "Include actionable recommendations",
                    "default": true
                  }
                },
                "required": ["user_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Eating pattern analysis",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "analysis_period": {
                      "type": "object",
                      "properties": {
                        "start_date": {"type": "string", "format": "date"},
                        "end_date": {"type": "string", "format": "date"},
                        "days_analyzed": {"type": "integer"}
                      }
                    },
                    "meal_timing_patterns": {
                      "type": "object",
                      "description": "When user typically eats",
                      "properties": {
                        "breakfast_time_avg": {"type": "string", "description": "Average breakfast time (HH:MM)"},
                        "lunch_time_avg": {"type": "string"},
                        "dinner_time_avg": {"type": "string"},
                        "consistency_score": {"type": "number", "description": "0-1, how consistent meal times are", "minimum": 0, "maximum": 1},
                        "meal_frequency_per_day": {"type": "number"}
                      }
                    },
                    "calorie_patterns": {
                      "type": "object",
                      "properties": {
                        "avg_daily_calories": {"type": "number"},
                        "highest_calorie_meal": {"type": "string", "enum": ["breakfast", "lunch", "dinner", "snack"]},
                        "weekend_vs_weekday_diff": {"type": "number", "description": "Calorie difference weekend vs weekday"},
                        "consistency_score": {"type": "number", "minimum": 0, "maximum": 1}
                      }
                    },
                    "macro_patterns": {
                      "type": "object",
                      "properties": {
                        "avg_protein_g": {"type": "number"},
                        "avg_carbs_g": {"type": "number"},
                        "avg_fat_g": {"type": "number"},
                        "protein_percentage": {"type": "number", "description": "% of calories from protein"},
                        "carbs_percentage": {"type": "number"},
                        "fat_percentage": {"type": "number"},
                        "macro_balance": {"type": "string", "description": "Balanced, high-protein, high-carb, etc."}
                      }
                    },
                    "food_preferences": {
                      "type": "object",
                      "properties": {
                        "most_frequent_foods": {
                          "type": "array",
                          "description": "Top 10 most logged foods",
                          "items": {
                            "type": "object",
                            "properties": {
                              "food_name": {"type": "string"},
                              "frequency": {"type": "integer"},
                              "avg_portion_size": {"type": "number"}
                            }
                          }
                        },
                        "food_variety_score": {"type": "number", "description": "0-1, how varied the diet is", "minimum": 0, "maximum": 1},
                        "dominant_categories": {
                          "type": "array",
                          "description": "Top food categories",
                          "items": {"type": "string"}
                        }
                      }
                    },
                    "adherence_patterns": {
                      "type": "object",
                      "properties": {
                        "logging_consistency": {"type": "number", "description": "% of days with logs", "minimum": 0, "maximum": 100},
                        "goal_adherence": {"type": "number", "description": "% of days meeting calorie target", "minimum": 0, "maximum": 100},
                        "macro_target_adherence": {"type": "number", "description": "% of days meeting macro targets", "minimum": 0, "maximum": 100},
                        "best_day_of_week": {"type": "string", "description": "Day with highest adherence"},
                        "worst_day_of_week": {"type": "string"}
                      }
                    },
                    "insights": {
                      "type": "array",
                      "description": "AI-generated insights",
                      "items": {
                        "type": "object",
                        "properties": {
                          "insight_type": {"type": "string", "enum": ["positive", "opportunity", "warning", "tip"]},
                          "title": {"type": "string"},
                          "description": {"type": "string"},
                          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
                        }
                      }
                    },
                    "recommendations": {
                      "type": "array",
                      "description": "Actionable recommendations",
                      "items": {
                        "type": "object",
                        "properties": {
                          "recommendation": {"type": "string"},
                          "priority": {"type": "string", "enum": ["high", "medium", "low"]},
                          "expected_impact": {"type": "string"}
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/analyze-fasting-patterns": {
      "post": {
        "summary": "Analyze fasting patterns",
        "description": "Analyze water fasting behavior, success rates, and adherence",
        "operationId": "analyzeFastingPatterns",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "user_id": {
                    "type": "string",
                    "description": "User ID (UUID)"
                  },
                  "lookback_days": {
                    "type": "integer",
                    "description": "Number of days to analyze",
                    "minimum": 7,
                    "maximum": 365,
                    "default": 30
                  }
                },
                "required": ["user_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Fasting pattern analysis",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "analysis_period": {
                      "type": "object",
                      "properties": {
                        "start_date": {"type": "string", "format": "date"},
                        "end_date": {"type": "string", "format": "date"},
                        "days_analyzed": {"type": "integer"}
                      }
                    },
                    "protocol_adherence": {
                      "type": "object",
                      "properties": {
                        "most_common_protocol": {"type": "string"},
                        "total_fasting_days": {"type": "integer"},
                        "completion_rate": {"type": "number", "description": "% of fasts completed", "minimum": 0, "maximum": 100},
                        "avg_fast_duration_hours": {"type": "number"},
                        "longest_fast_hours": {"type": "number"},
                        "current_streak_days": {"type": "integer"}
                      }
                    },
                    "timing_patterns": {
                      "type": "object",
                      "properties": {
                        "preferred_start_time": {"type": "string", "description": "Most common fast start time (HH:MM)"},
                        "preferred_end_time": {"type": "string"},
                        "best_day_to_start": {"type": "string", "description": "Day of week with highest success"},
                        "consistency_score": {"type": "number", "minimum": 0, "maximum": 1}
                      }
                    },
                    "success_factors": {
                      "type": "object",
                      "properties": {
                        "completion_by_duration": {
                          "type": "object",
                          "description": "Success rates by duration",
                          "properties": {
                            "under_16h": {"type": "number"},
                            "16_to_18h": {"type": "number"},
                            "18_to_24h": {"type": "number"},
                            "over_24h": {"type": "number"}
                          }
                        },
                        "completion_by_day_of_week": {
                          "type": "object",
                          "description": "Success rates by day",
                          "additionalProperties": {"type": "number"}
                        }
                      }
                    },
                    "health_correlations": {
                      "type": "object",
                      "properties": {
                        "weight_loss_correlation": {"type": "number", "description": "Correlation between fasting and weight loss", "minimum": -1, "maximum": 1},
                        "avg_weight_change_on_fasting_days": {"type": "number", "description": "kg"},
                        "energy_level_pattern": {"type": "string", "description": "User-reported energy levels"}
                      }
                    },
                    "insights": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "insight_type": {"type": "string", "enum": ["positive", "opportunity", "warning", "tip"]},
                          "title": {"type": "string"},
                          "description": {"type": "string"}
                        }
                      }
                    },
                    "recommendations": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "recommendation": {"type": "string"},
                          "rationale": {"type": "string"}
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/generate-insights": {
      "post": {
        "summary": "Generate personalized insights",
        "description": "Use AI to generate personalized health insights from user data",
        "operationId": "generateInsights",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "user_id": {
                    "type": "string",
                    "description": "User ID (UUID)"
                  },
                  "insight_focus": {
                    "type": "string",
                    "description": "Focus area for insights",
                    "enum": ["overall", "eating", "fasting", "goal_progress", "exercise"],
                    "default": "overall"
                  },
                  "lookback_days": {
                    "type": "integer",
                    "description": "Days of data to consider",
                    "minimum": 7,
                    "maximum": 90,
                    "default": 14
                  },
                  "include_predictions": {
                    "type": "boolean",
                    "description": "Include forward-looking predictions",
                    "default": true
                  }
                },
                "required": ["user_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Personalized insights and recommendations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "summary": {
                      "type": "string",
                      "description": "High-level summary of user's progress"
                    },
                    "key_wins": {
                      "type": "array",
                      "description": "Positive achievements to celebrate",
                      "items": {
                        "type": "object",
                        "properties": {
                          "title": {"type": "string"},
                          "description": {"type": "string"},
                          "metric": {"type": "string", "description": "Supporting data"}
                        }
                      }
                    },
                    "opportunities": {
                      "type": "array",
                      "description": "Areas for improvement",
                      "items": {
                        "type": "object",
                        "properties": {
                          "title": {"type": "string"},
                          "description": {"type": "string"},
                          "suggested_action": {"type": "string"},
                          "potential_impact": {"type": "string"}
                        }
                      }
                    },
                    "predictions": {
                      "type": "object",
                      "description": "Forward-looking predictions",
                      "properties": {
                        "goal_completion_date": {"type": "string", "format": "date", "description": "Predicted goal completion"},
                        "weight_in_30_days": {"type": "number", "description": "Predicted weight if current trends continue"},
                        "confidence": {"type": "number", "minimum": 0, "maximum": 1, "description": "Confidence in prediction"}
                      }
                    },
                    "behavioral_insights": {
                      "type": "array",
                      "description": "Insights about behavior patterns",
                      "items": {
                        "type": "object",
                        "properties": {
                          "insight": {"type": "string"},
                          "pattern_detected": {"type": "string"},
                          "frequency": {"type": "string"}
                        }
                      }
                    },
                    "action_items": {
                      "type": "array",
                      "description": "Specific, actionable next steps",
                      "items": {
                        "type": "object",
                        "properties": {
                          "action": {"type": "string"},
                          "priority": {"type": "string", "enum": ["high", "medium", "low"]},
                          "timeframe": {"type": "string", "description": "When to do it"},
                          "expected_benefit": {"type": "string"}
                        }
                      }
                    },
                    "motivational_message": {
                      "type": "string",
                      "description": "Personalized encouragement from Amigo"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/compare-periods": {
      "post": {
        "summary": "Compare time periods",
        "description": "Compare user metrics and behavior across different time periods",
        "operationId": "comparePeriods",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "user_id": {
                    "type": "string",
                    "description": "User ID (UUID)"
                  },
                  "period1_start": {
                    "type": "string",
                    "format": "date",
                    "description": "Start date of first period"
                  },
                  "period1_end": {
                    "type": "string",
                    "format": "date",
                    "description": "End date of first period"
                  },
                  "period2_start": {
                    "type": "string",
                    "format": "date",
                    "description": "Start date of second period"
                  },
                  "period2_end": {
                    "type": "string",
                    "format": "date",
                    "description": "End date of second period"
                  }
                },
                "required": ["user_id", "period1_start", "period1_end", "period2_start", "period2_end"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Period comparison analysis",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "period1": {
                      "type": "object",
                      "properties": {
                        "start_date": {"type": "string", "format": "date"},
                        "end_date": {"type": "string", "format": "date"},
                        "avg_daily_calories": {"type": "number"},
                        "avg_weight_kg": {"type": "number"},
                        "logging_consistency": {"type": "number"},
                        "fasting_days": {"type": "integer"}
                      }
                    },
                    "period2": {
                      "type": "object",
                      "properties": {
                        "start_date": {"type": "string", "format": "date"},
                        "end_date": {"type": "string", "format": "date"},
                        "avg_daily_calories": {"type": "number"},
                        "avg_weight_kg": {"type": "number"},
                        "logging_consistency": {"type": "number"},
                        "fasting_days": {"type": "integer"}
                      }
                    },
                    "changes": {
                      "type": "object",
                      "properties": {
                        "calorie_change": {"type": "number", "description": "Difference in avg daily calories"},
                        "weight_change_kg": {"type": "number"},
                        "logging_change": {"type": "number", "description": "Change in consistency %"},
                        "fasting_change": {"type": "integer", "description": "Change in fasting days"}
                      }
                    },
                    "interpretation": {
                      "type": "string",
                      "description": "AI-generated interpretation of the changes"
                    },
                    "recommendations": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
